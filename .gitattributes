# Keep shell scripts + macOS .command launchers as LF on every platform,
# regardless of the cloner's core.autocrlf — CRLF breaks bash/sh on
# Linux/macOS ("bad interpreter" / \r errors).
*.sh        text eol=lf
*.bash      text eol=lf
*.command   text eol=lf

# Windows batch/PowerShell want CRLF.
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Treat the bundled binaries + media as binary (never line-ending munged).
*.exe       binary
*.dll       binary
*.zip       binary
*.png       binary
*.ico       binary
*.onnx      binary
