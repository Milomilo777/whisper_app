*.spec.bak

# Virtual environments
.venv/
venv/
env/
ENV/
.env

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# Project-specific
# Bundled binaries — too large for git, document the download in README instead
bin/ffmpeg.exe
bin/ffprobe.exe
bin/yt-dlp.exe

# Diarisation ONNX models — fetched by tools/download_diarization_models.bat
# at build time. ~35 MB total; not committed for the same reason as the
# Whisper model.
bin/diarization/*.onnx
bin/diarization/*.tar.bz2

# Local config that may contain absolute paths / personal cache locations
config.local.json
# Migration / corruption artifacts (Phase 1.2)
config.json.corrupt
config.json.migrated.bak

# Logs (when Phase 1 lands)
logs/
*.log

# Test artifact dirs from acceptance runs
test_output_*/

# PyInstaller build outputs
build/
dist/
dist_onedir/
dist_installer/
build_logs/

# Method C embed-tree (regenerated by build_embed_installer.bat)
embed_build/

# Bundled service-account key for trusted-distribution builds — NEVER commit it.
# It lives only inside a build tree (embed_build/creds/), never in the repo.
creds/
gcloud_stt.json

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
.tox/

# Type checker caches
.mypy_cache/
.pyright/
.ruff_cache/

# OS junk
.AppleDouble
.LSOverride

# Claude Code session scratch — worktrees, briefs, rebuild logs, e2e drivers
# (local, ephemeral; per-machine permission settings too)
.claude/

# Local notes that should not be committed
New Text Document.txt
NOTES.local.md
TODO.local.md

# Live SMTV E2E fixtures — downloaded on demand; keep out of repo
tests/fixtures/smtv_clip/
